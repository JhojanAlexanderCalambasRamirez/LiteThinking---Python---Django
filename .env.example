# =============================================================================
# LiteThinking - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---
DB_NAME=litethinking_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/litethinking_db

# --- Django ---
DJANGO_SECRET_KEY=your-django-secret-key-change-this-in-production

# --- Services URLs (used by Django to call microservices) ---
INVENTORY_SERVICE_URL=http://localhost:8001
AI_AGENT_SERVICE_URL=http://localhost:8002

# --- Email (choose one: smtp or sendgrid) ---
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
# --- OR SendGrid ---
# EMAIL_BACKEND=sendgrid
# SENDGRID_API_KEY=SG.your_key_here

# --- AI ---
# OPENAI_API_KEY not needed — embeddings run locally via sentence-transformers
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- Blockchain (optional - set BLOCKCHAIN_ENABLED=false to disable) ---
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_RPC_URL=https://rpc-mumbai.maticvigil.com
BLOCKCHAIN_PRIVATE_KEY=0x_your_wallet_private_key
BLOCKCHAIN_CONTRACT_ADDRESS=0x_your_contract_address

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AI_AGENT_URL=http://localhost:8002
